@{
    ViewData["Title"] = "- Register";
}

@model prototype.Models.Registration.StepOneModel

<div class="container" id="main-container">
    <div id="content-form" class="p-5 mt-3">
        <div class="progress" role="progressbar" aria-label="Animated striped example" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">
            <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 20%"></div>
        </div>

        <h1 class="mt-3">Basic Information</h1>
        <hr class="divider" />

        <form asp-action="PersonalInfo" method="post" id="registrationForm">
            <div class="d-flex flex-column w-auto gap-3 form-steps">
                <div class="d-flex flex-column step1">
                    <label asp-for="ApplicationDate" class="fw-bold">Application Date</label>
                    <input asp-for="ApplicationDate" id="date" class="form-control" readonly />
                </div>
                <div class="d-flex flex-column step1">
                    <label for="lrn" class="fw-bold">LRN</label>
                    <input type="number" name="LRN" id="lrn" class="form-control" placeholder="XXXXXXXXXXXX" required />
                </div>
                <div class="d-flex flex-column step1">
                    <label for="studentNumber" class="fw-bold">Student Number</label>
                    <input type="text" name="StudentNumber" id="studentNumber" placeholder="XX-XXXX" class="form-control" required/>
                </div>
            </div>

            <hr class="divider" />
            <p class="fw-bold">Applying as (Choose appropriate answer)</p>

            <div class="mb-3 d-flex gap-3 align-items-center">
                <label for="shs" style="height: 100%"><input type="radio" name="ApplyingAs" id="shs" value="SHS" /> Senior High School Graduate</label>

                <div class="d-flex flex-column step1">
                    <label asp-for="Track" class="fw-bold">Track</label>
                    <select name="Track" id="track" class="form-select" disabled>
                        <option value="" selected>Select One</option>
                        <option value="Academic">Academic</option>
                        <option value="Technical-Vocational-Livelihood">Technical-Vocational-Livelihood</option>
                    </select>
                </div>

                <div class="d-flex flex-column step1">
                    <label asp-for="Strand" class="fw-bold">Strand</label>
                    <select name="Strand" id="strand" class="form-select" disabled>
                        <option value="" selected>Select One</option>
                        <option value="ABM">ABM</option>
                        <option value="HUMSS">HUMSS</option>
                        <option value="STEM">STEM</option>
                    </select>
                </div>

            </div>

            <div class="input-group gap-1 mb-3">
                <label for="hsGraduate"><input type="radio" name="ApplyingAs" id="hsGraduate" value="HSGraduate" /> High School Graduate (Year 2015 and below)</label>
            </div>
            
            <label for="transferee" class="mb-3 "><input type="radio" name="ApplyingAs" id="transferee" value="Transferee" /> Transferee</label> 
            
            <br />

            @* <div class="input-group align-items-baseline mb-3">
                Applying for Accreditation of Subjects? 
                <div class="dropdown d-inline-block ms-1">
                    <button class="btn border-black dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Select One</button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">Yes</a></li>
                        <li><a class="dropdown-item" href="#">No</a></li>
                    </ul>
                </div>
            </div> *@

            
            <label for="2ndDegree"><input type="radio" name="ApplyingAs" id="2ndDegree" value="SecondDegree" /> 2nd Degree Course Taker (Graduate of Bachelor’s Degree)</label>

            <hr class="divider" />

            <div class="d-flex flex-column gap-3 preference-selection">
                <div>
                    <p class="fw-bold">Preferred Course</p>
                    <div class="courseWidth d-flex align-items-baseline flex-column gap-3">

                        <div class="choice-container">
                            <div class="choice">First Choice</div>
                            <select class="form-select d-inline-block course" name="FirstChoice" required>
                                <option selected>Select One</option>
                                <option value="BECEd">Bachelor of Early Childhood Education</option>
                                <option value="BSA">Bachelor of Science in Accountancy</option>
                                <option value="BSCS">Bachelor of Science in Computer Science</option>
                            </select>
                        </div>

                        <div class="choice-container">
                        <div class="choice">Second Choice</div>
                            <select class="form-select d-inline-block course" name="SecondChoice" required>
                            <option selected>Select One</option>
                            <option value="BECEd">Bachelor of Early Childhood Education</option>
                            <option value="BSA">Bachelor of Science in Accountancy</option>
                        </select>
                        </div>

                        <div class="choice-container">
                        <div class="choice">Third Choice</div>
                            <select class="form-select d-inline-block course" name="ThirdChoice" required>
                            <option selected>Select One</option>
                            <option value="BECEd">Bachelor of Early Childhood Education</option>
                            <option value="BSA">Bachelor of Science in Accountancy</option>
                        </select>
                        </div>

                        <div class="choice-container">
                        <div class="choice">Currently Enrolled?</div>
                        <select class="mb-3 form-select d-inline-block course" name="CurrentlyEnrolled" id="currentlyEnrolled" required>
                            <option selected>Select One</option>
                            <option value="Yes">Yes</option>
                            <option value="No">No</option>
                        </select>
                        </div>
                    </div>

                    <input type="text" name="SchoolName" id="schoolName" placeholder="Name Of School" class="form-control" disabled/>
                </div>

                <div>
                    <p class="fw-bold">Preferred Campus</p>

                    <div class="courseWidth d-flex align-items-baseline flex-column gap-3">

                        <div class="choice-container">
                            <div class="choice">First Choice</div>
                            <select class="form-select d-inline-block course" name="FirstCampusChoice" required>
                                <option selected>Select One</option>
                                <option value="sb">San Bartolome</option>
                                <option value="sf">San Francisco</option>
                                <option value="ba">Batasan</option>
                            </select>
                        </div>

                        <div class="choice-container">
                            <div class="choice">Second Choice</div>
                            <select class="form-select d-inline-block course" name="SecondCampusChoice" required>
                                <option selected>Select One</option>
                                <option value="sb">San Bartolome</option>
                                <option value="sf">San Francisco</option>
                                <option value="ba">Batasan</option>
                            </select>
                        </div>

                        <div class="choice-container">
                            <div class="choice">Third Choice</div>
                            <select class="form-select d-inline-block course" name="ThirdCampusChoice" required>
                                <option selected>Select One</option>
                                <option value="sb">San Bartolome</option>
                                <option value="sf">San Francisco</option>
                                <option value="ba">Batasan</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <p class="text-end mt-3 mb-0">
                <button id="nextButton" class="btn next text-white" type="submit">Next <i class="fa-solid fa-chevron-right"></i></button>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('registrationForm');
            const nextButton = document.getElementById('nextButton');

            form.addEventListener('submit', function (e) {
                const requiredFields = form.querySelectorAll('[required]');
                let allFieldsValid = true;

                requiredFields.forEach(field => {
                    if (!field.disabled && field.offsetParent !== null) {
                        if (!field.value.trim() || field.value === "Select One") {
                            allFieldsValid = false;
                            field.classList.add('is-invalid'); 
                        } else {
                            field.classList.remove('is-invalid');
                        }
                    }
                });

                const applyingAsRadios = document.querySelectorAll('input[name="ApplyingAs"]');
                const applyingAsChecked = Array.from(applyingAsRadios).some(radio => radio.checked);
                if (!applyingAsChecked) {
                    allFieldsValid = false;
                    alert('Please select an option for "Applying As."');
                }

                if (!allFieldsValid) {
                    e.preventDefault();
                    alert('Please fill out all required fields before proceeding.');
                }
            });

            const shsRadio = document.getElementById('shs');
            const track = document.getElementById('track');
            const strand = document.getElementById('strand');
            const applyingAsRadios = document.querySelectorAll('input[name="ApplyingAs"]');

            applyingAsRadios.forEach(radio => {
                radio.addEventListener('change', function () {
                    if (shsRadio.checked) {
                        track.disabled = false;
                        strand.disabled = false;
                        track.setAttribute('required', 'true');
                        strand.setAttribute('required', 'true');
                    } else {
                        track.disabled = true;
                        strand.disabled = true;
                        track.removeAttribute('required');
                        strand.removeAttribute('required');
                        track.value = "";
                        strand.value = "";
                    }
                });
            });

            const currentlyEnrolled = document.getElementById('currentlyEnrolled');
            const schoolName = document.getElementById('schoolName');

            currentlyEnrolled.addEventListener('change', function () {
                if (this.value === "Yes") {
                    schoolName.disabled = false;
                    schoolName.setAttribute('required', 'true');
                } else {
                    schoolName.disabled = true;
                    schoolName.removeAttribute('required');
                    schoolName.value = "";
                }
            });
        });
    </script>
}