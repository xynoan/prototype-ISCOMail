@{
    ViewData["Title"] = "- Register";
}

@model prototype.Models.Registration.PersonalInfoModel

<div class="container" id="main-container">
    <div id="content-form" class="p-5 mt-3">
        <!-- Progress Bar -->
        <div class="progress" role="progressbar" aria-label="Animated striped example" aria-valuenow="40" aria-valuemin="0" aria-valuemax="100">
            <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 40%"></div>
        </div>

        <h1 class="mt-3">Personal Information</h1>
        <hr class="divider" />

        <!-- Form -->
        <form asp-action="Education" method="post">
            <!-- Full Name -->
            <p class="fw-bold">Full Name</p>
            <div class="input-group d-flex flex-column personal-details-form">
                <input asp-for="LastName" placeholder="Last Name" class="form-control w-100" />
                <span asp-validation-for="LastName" class="text-danger"></span>

                <input asp-for="FirstName" placeholder="First Name" class="form-control w-100" />
                <span asp-validation-for="FirstName" class="text-danger"></span>

                <input asp-for="MiddleName" placeholder="Middle Name" class="form-control w-100" />
                <span asp-validation-for="MiddleName" class="text-danger"></span>

                <input asp-for="Suffix" placeholder="Suffix" class="form-control w-100" />
            </div>

            <!-- Background Info -->
            <div class="mt-3 d-flex flex-column w-auto gap-3 background-info-form">
                <div class="d-flex flex-column">
                    <p class="fw-bold">Date of Birth</p>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>
                <div class="d-flex flex-column">
                    <p class="fw-bold">Birth Place</p>
                    <input asp-for="BirthPlace" placeholder="Select Place" class="form-control" />
                    <span asp-validation-for="BirthPlace" class="text-danger"></span>
                </div>
                <div class="d-flex flex-column">
                    <p class="fw-bold">Gender</p>
                    <select asp-for="Gender" class="form-select">
                        <option selected>Select One</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="LGBTQIA+">LGBTQIA+</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>
            </div>

            <!-- Additional Info -->
            <div class="mt-3 d-flex flex-column background-info-form">
                <div class="d-flex flex-column">
                    <p class="fw-bold">Religion</p>
                    <select asp-for="Religion" class="form-select">
                        <option selected>Select One</option>
                        <option value="Catholic">Catholic</option>
                        <option value="Muslim">Muslim</option>
                        <option value="Christian">Christian</option>
                        <option value="Buddhist">Buddhist</option>
                    </select>
                    <span asp-validation-for="Religion" class="text-danger"></span>
                </div>
                <div class="d-flex flex-column">
                    <p class="fw-bold">Citizenship</p>
                    <input asp-for="Citizenship" class="form-control" />
                    <span asp-validation-for="Citizenship" class="text-danger"></span>
                </div>
                <div class="d-flex flex-column">
                    <p class="fw-bold">Civil Status</p>
                    <select asp-for="CivilStatus" class="form-select">
                        <option selected>Select One</option>
                        <option value="Single">Single</option>
                        <option value="Married">Married</option>
                        <option value="Divorced">Divorced</option>
                        <option value="Widowed">Widowed</option>
                    </select>
                    <span asp-validation-for="CivilStatus" class="text-danger"></span>
                </div>
            </div>

            <!-- Address -->
            <p class="fw-bold mt-3">Present Address</p>
            <div class="input-group d-flex flex-column personal-details-form">
                <input asp-for="HouseStreet" placeholder="House No./Street" class="form-control w-100" />
                <span asp-validation-for="HouseStreet" class="text-danger"></span>

                <input asp-for="Barangay" placeholder="Barangay" class="form-control w-100" />
                <span asp-validation-for="Barangay" class="text-danger"></span>

                <input asp-for="Municipality" placeholder="Municipality" class="form-control w-100" />
                <span asp-validation-for="Municipality" class="text-danger"></span>

                <input asp-for="District" placeholder="District" class="form-control w-100" />
                <span asp-validation-for="District" class="text-danger"></span>

                <input asp-for="ZipCode" placeholder="Zip Code" class="form-control w-100" />
                <span asp-validation-for="ZipCode" class="text-danger"></span>
            </div>

            <!-- Navigation Buttons -->
            <div class="d-flex justify-content-between mt-4">
                <button class="btn next text-white" id="previousButton" type="button" onclick="window.location.href='@Url.Action("Index", "Register")'">
                    <i class="fa-solid fa-chevron-left"></i> Previous
                </button>
                <button class="btn next text-white" type="submit">Next <i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
}
